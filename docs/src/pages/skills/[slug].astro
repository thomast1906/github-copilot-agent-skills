---
import BaseLayout from '../../components/layout/BaseLayout.astro';
import StatusBadge from '../../components/ui/StatusBadge.astro';
import CategoryBadge from '../../components/ui/CategoryBadge.astro';
import AgentCard from '../../components/cards/AgentCard.astro';
import PackageCard from '../../components/cards/PackageCard.astro';
import { getCollection, type CollectionEntry } from 'astro:content';
import { mcpServers } from '../../site.config';

export async function getStaticPaths() {
  const skills = await getCollection('skills');
  return skills.map((skill) => ({
    params: { slug: skill.id },
    props: { skill },
  }));
}

interface Props {
  skill: CollectionEntry<'skills'>;
}

const { skill } = Astro.props;
const baseUrl = import.meta.env.BASE_URL || '/github-copilot-agent-skills';

const relatedMcpServers = mcpServers.filter(server =>
  skill.data.metadata.mcp.includes(server.id)
);

const allAgents = await getCollection('agents');
const relatedAgents = allAgents.filter(agent =>
  agent.data.metadata.skills.includes(skill.id)
);

const allPackages = await getCollection('packages');
const relatedPackages = allPackages.filter(pkg =>
  pkg.data.skills.includes(skill.id)
);

const githubUrl = `https://github.com/thomast1906/github-copilot-agent-skills/blob/main/.github/skills/${skill.id}/SKILL.md`;
---

<BaseLayout
  title={skill.data.name}
  description={skill.data.description}
>
  <article class="page">
    <div class="container">
      <a href={`${baseUrl}/skills/`} class="back-link">← Back to Skills</a>

      <header class="skill-header">
        <h1>{skill.data.name}</h1>
        <div class="badges">
          <StatusBadge status={skill.data.metadata.status} />
          <CategoryBadge category={skill.data.metadata.category} />
          {skill.data.metadata.version && <span class="meta-badge">v{skill.data.metadata.version}</span>}
          {skill.data.metadata.lastUpdated && <span class="meta-badge">Updated {skill.data.metadata.lastUpdated}</span>}
        </div>
      </header>

      <p class="description">{skill.data.description}</p>

      {skill.data.metadata.azureServices.length > 0 && (
        <div class="azure-services">
          <span class="services-label">Azure services:</span>
          {skill.data.metadata.azureServices.map(svc => (
            <span class="service-tag">{svc}</span>
          ))}
        </div>
      )}

      {skill.data.metadata.examples.length > 0 && (
        <section class="examples-section">
          <h2>Example prompts</h2>
          <ul class="examples-list">
            {skill.data.metadata.examples.map((ex) => (
              <li class="example-item">
                <span class="example-icon">💬</span>
                <span class="example-text">{ex}</span>
              </li>
            ))}
          </ul>
        </section>
      )}

      <div class="source-link-row">
        <div class="install-row">
          <span class="install-label">Quick install:</span>
          <code class="install-cmd">apm install thomast1906/github-copilot-agent-skills/.github/skills/{skill.id} --runtime vscode</code>
          <button class="copy-install-btn" data-cmd={`apm install thomast1906/github-copilot-agent-skills/.github/skills/${skill.id} --runtime vscode`} aria-label="Copy install command">
            <svg width="14" height="14" viewBox="0 0 16 16" fill="currentColor">
              <path d="M0 6.75C0 5.784.784 5 1.75 5h1.5a.75.75 0 0 1 0 1.5h-1.5a.25.25 0 0 0-.25.25v7.5c0 .138.112.25.25.25h7.5a.25.25 0 0 0 .25-.25v-1.5a.75.75 0 0 1 1.5 0v1.5A1.75 1.75 0 0 1 9.25 16h-7.5A1.75 1.75 0 0 1 0 14.25Z"></path>
              <path d="M5 1.75C5 .784 5.784 0 6.75 0h7.5C15.216 0 16 .784 16 1.75v7.5A1.75 1.75 0 0 1 14.25 11h-7.5A1.75 1.75 0 0 1 5 9.25Zm1.75-.25a.25.25 0 0 0-.25.25v7.5c0 .138.112.25.25.25h7.5a.25.25 0 0 0 .25-.25v-7.5a.25.25 0 0 0-.25-.25Z"></path>
            </svg>
            Copy
          </button>
        </div>
        <a href={githubUrl} target="_blank" rel="noopener noreferrer" class="source-link">
          View skill spec on GitHub
          <svg width="14" height="14" viewBox="0 0 16 16" fill="currentColor">
            <path d="M3.75 2h3.5a.75.75 0 0 1 0 1.5h-3.5a.25.25 0 0 0-.25.25v8.5c0 .138.112.25.25.25h8.5a.25.25 0 0 0 .25-.25v-3.5a.75.75 0 0 1 1.5 0v3.5A1.75 1.75 0 0 1 12.25 14h-8.5A1.75 1.75 0 0 1 2 12.25v-8.5C2 2.784 2.784 2 3.75 2Zm6.854-1h4.146a.25.25 0 0 1 .25.25v4.146a.25.25 0 0 1-.427.177L13.03 4.03 9.28 7.78a.751.751 0 0 1-1.042-.018.751.751 0 0 1-.018-1.042l3.75-3.75-1.543-1.543A.25.25 0 0 1 10.604 1Z"></path>
          </svg>
        </a>
      </div>

      {relatedMcpServers.length > 0 && (
        <section class="section">
          <h2>MCP Requirements</h2>
          <p class="section-intro">This skill requires the following MCP servers to be configured:</p>
          <div class="mcp-list">
            {relatedMcpServers.map((server) => (
              <div class="mcp-item">
                <h3>{server.name}</h3>
                <p>{server.description}</p>
                <div class="setup-box">
                  <strong>Setup:</strong> {server.installation}
                </div>
              </div>
            ))}
          </div>
        </section>
      )}

      {relatedAgents.length > 0 && (
        <section class="section">
          <h2>Related Agents</h2>
          <p class="section-intro">This skill is used by the following agents:</p>
          <div class="agents-grid">
            {relatedAgents.map((agent) => (
              <AgentCard agent={agent} />
            ))}
          </div>
        </section>
      )}

      {relatedPackages.length > 0 && (
        <section class="section">
          <h2>Included in Packages</h2>
          <p class="section-intro">Install this skill as part of these packages:</p>
          <div class="packages-grid">
            {relatedPackages.map((pkg) => (
              <PackageCard package={pkg} />
            ))}
          </div>
        </section>
      )}
    </div>
  </article>
</BaseLayout>

<style>
  .page {
    padding: var(--space-20) 0 var(--space-24);
  }

  .back-link {
    display: inline-flex;
    align-items: center;
    color: var(--color-text-link);
    font-size: var(--text-sm);
    font-weight: 600;
    text-decoration: none;
    margin-bottom: var(--space-8);
  }

  .back-link:hover {
    text-decoration: underline;
  }

  .skill-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: var(--space-6);
    margin-bottom: var(--space-6);
    flex-wrap: wrap;
  }

  h1 {
    font-size: var(--text-5xl);
    font-weight: 700;
    line-height: var(--leading-tight);
    color: var(--color-text-primary);
  }

  @media (max-width: 768px) {
    h1 {
      font-size: var(--text-4xl);
    }
  }

  .badges {
    display: flex;
    gap: var(--space-3);
    flex-wrap: wrap;
    align-items: center;
  }

  .meta-badge {
    display: inline-block;
    background: var(--color-bg-tertiary);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-full, 9999px);
    padding: var(--space-1) var(--space-3);
    font-size: var(--text-xs);
    color: var(--color-text-secondary);
    font-weight: 500;
  }

  .azure-services {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: var(--space-2);
    margin-bottom: var(--space-6);
  }

  .services-label {
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--color-text-secondary);
    margin-right: var(--space-1);
  }

  .service-tag {
    display: inline-block;
    background: var(--color-bg-secondary);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-full, 9999px);
    padding: 2px var(--space-3);
    font-size: var(--text-xs);
    font-family: var(--font-mono, monospace);
    color: var(--color-text-secondary);
  }

  .description {
    font-size: var(--text-xl);
    line-height: var(--leading-relaxed);
    color: var(--color-text-secondary);
    margin-bottom: var(--space-8);
  }

  .examples-section {
    margin-bottom: var(--space-8);
  }

  .examples-section h2 {
    font-size: var(--text-2xl);
    font-weight: 700;
    color: var(--color-text-primary);
    margin-bottom: var(--space-4);
  }

  .examples-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .example-item {
    display: flex;
    align-items: flex-start;
    gap: var(--space-3);
    background: var(--color-bg-secondary);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    padding: var(--space-4) var(--space-5);
  }

  .example-icon {
    font-size: var(--text-base);
    flex-shrink: 0;
    margin-top: 1px;
  }

  .example-text {
    font-size: var(--text-base);
    color: var(--color-text-secondary);
    line-height: var(--leading-relaxed);
    font-style: italic;
  }

  .source-link-row {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    margin-bottom: var(--space-12);
  }

  .install-row {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    background: var(--color-bg-secondary);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    padding: var(--space-3) var(--space-4);
    flex-wrap: wrap;
  }

  .install-label {
    font-size: var(--text-xs);
    font-weight: 600;
    color: var(--color-text-secondary);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    flex-shrink: 0;
  }

  .install-cmd {
    flex: 1;
    font-size: var(--text-sm);
    font-family: var(--font-mono, monospace);
    color: var(--color-text-primary);
    word-break: break-all;
  }

  .copy-install-btn {
    display: inline-flex;
    align-items: center;
    gap: var(--space-1);
    padding: var(--space-1) var(--space-3);
    background: var(--color-bg-tertiary);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    color: var(--color-text-secondary);
    font-size: var(--text-xs);
    cursor: pointer;
    transition: all 0.2s ease;
    flex-shrink: 0;
  }

  .copy-install-btn:hover {
    color: var(--color-text-primary);
  }

  .source-link {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    color: var(--color-text-link);
    font-size: var(--text-sm);
    font-weight: 600;
    text-decoration: none;
  }

  .source-link:hover {
    text-decoration: underline;
  }

  .section {
    margin-top: var(--space-16);
    padding-top: var(--space-16);
    border-top: 1px solid var(--color-border);
  }

  .section h2 {
    font-size: var(--text-3xl);
    font-weight: 700;
    line-height: var(--leading-tight);
    color: var(--color-text-primary);
    margin-bottom: var(--space-4);
  }

  .section-intro {
    font-size: var(--text-lg);
    color: var(--color-text-secondary);
    margin-bottom: var(--space-8);
  }

  .mcp-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
  }

  .mcp-item {
    background: var(--color-bg-secondary);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    padding: var(--space-6);
  }

  .mcp-item h3 {
    font-size: var(--text-xl);
    font-weight: 600;
    color: var(--color-text-primary);
    margin-bottom: var(--space-3);
  }

  .mcp-item p {
    color: var(--color-text-secondary);
    line-height: var(--leading-relaxed);
    margin-bottom: var(--space-4);
  }

  .setup-box {
    background: var(--color-bg-tertiary);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    padding: var(--space-4);
    font-size: var(--text-sm);
    color: var(--color-text-secondary);
  }

  .setup-box strong {
    color: var(--color-text-primary);
  }

  .agents-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: var(--space-6);
  }

  @media (min-width: 768px) {
    .agents-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  .packages-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
    gap: var(--space-8);
  }

  @media (min-width: 1024px) {
    .packages-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
</style>

<script>
  document.querySelectorAll('.copy-install-btn').forEach(btn => {
    btn.addEventListener('click', async () => {
      const cmd = btn.getAttribute('data-cmd') || '';
      try {
        await navigator.clipboard.writeText(cmd);
        const orig = btn.textContent?.trim();
        btn.textContent = '✓ Copied';
        setTimeout(() => { btn.textContent = orig || 'Copy'; }, 2000);
      } catch {}
    });
  });
</script>
