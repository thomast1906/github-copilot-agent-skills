---
import type { CollectionEntry } from 'astro:content';

interface Props {
  agent: CollectionEntry<'agents'>;
}

const { agent } = Astro.props;
const baseUrl = import.meta.env.BASE_URL;
const skillCount = agent.data.metadata.skills?.length ?? 0;
---

<article class="agent-card">
  <a href={`${baseUrl}/agents/${agent.id}/`} class="card-link">
    <div class="agent-icon" aria-hidden="true">🤖</div>
    <div class="card-body">
      <div class="card-top">
        <h3>{agent.data.name}</h3>
        {skillCount > 0 && (
          <span class="skill-count" title={`Uses ${skillCount} skill${skillCount === 1 ? '' : 's'}`}>
            {skillCount} skill{skillCount === 1 ? '' : 's'}
          </span>
        )}
      </div>
      <p class="description">{agent.data.description}</p>
      <span class="view-hint">View agent →</span>
    </div>
  </a>
</article>

<style>
  .agent-card {
    background: var(--color-bg-secondary);
    border: 1px solid var(--color-border);
    border-top: 3px solid var(--color-accent-secondary);
    border-radius: var(--radius-md);
    transition: border-color 0.2s ease, transform 0.2s ease, box-shadow 0.2s ease;
    min-width: 0;
  }

  .agent-card:hover {
    border-color: var(--color-accent-secondary);
    transform: translateY(-2px);
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.35);
  }

  .card-link {
    display: flex;
    align-items: flex-start;
    gap: var(--space-4);
    padding: var(--space-5) var(--space-6);
    text-decoration: none;
    color: inherit;
  }

  .agent-icon {
    font-size: 1.75rem;
    line-height: 1;
    flex-shrink: 0;
    margin-top: 2px;
  }

  .card-body {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    min-width: 0;
    flex: 1;
  }

  .card-top {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: var(--space-3);
  }

  h3 {
    font-size: var(--text-lg);
    font-weight: 700;
    line-height: var(--leading-tight);
    color: var(--color-text-primary);
  }

  .skill-count {
    font-size: var(--text-xs);
    font-weight: 600;
    padding: 2px var(--space-2);
    background: rgba(35, 134, 54, 0.15);
    color: var(--color-accent-secondary);
    border-radius: var(--radius-sm);
    white-space: nowrap;
    flex-shrink: 0;
  }

  .description {
    color: var(--color-text-secondary);
    font-size: var(--text-sm);
    line-height: var(--leading-relaxed);
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .view-hint {
    font-size: var(--text-xs);
    font-weight: 600;
    color: var(--color-accent-secondary);
    opacity: 0;
    transition: opacity 0.2s ease;
  }

  .agent-card:hover .view-hint {
    opacity: 1;
  }
</style>
