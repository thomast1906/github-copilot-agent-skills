---
import { categories, type CategorySlug } from '../../config/categories';

interface Props {
  category: CategorySlug;
}

const { category } = Astro.props;
const categoryData = categories[category];
const categoryName = categoryData?.name || category;
const categoryColor = categoryData?.color || 'var(--color-text-secondary)';
---

<span class="category-badge">
  <span class="dot" style={`background: ${categoryColor};`}></span>
  {categoryName}
</span>

<style>
  .category-badge {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    font-size: var(--text-sm);
    color: var(--color-text-secondary);
  }

  .dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
  }
</style>
