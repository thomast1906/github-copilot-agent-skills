---
const currentPath = Astro.url.pathname;
const baseUrl = import.meta.env.BASE_URL || '/github-copilot-agent-skills';
---

<header class="header">
  <div class="container">
    <div class="header-content">
      <a href={`${baseUrl}/`} class="logo">
        ⚡ Agent Skills
      </a>
      
      <nav class="nav" id="nav">
        <a 
          href={`${baseUrl}/skills/`} 
          class="nav-link"
          aria-current={currentPath.startsWith(`${baseUrl}/skills`) ? 'page' : undefined}
        >
          Skills
        </a>
        <a 
          href={`${baseUrl}/agents/`} 
          class="nav-link"
          aria-current={currentPath.startsWith(`${baseUrl}/agents`) ? 'page' : undefined}
        >
          Agents
        </a>
        <a 
          href={`${baseUrl}/packages/`} 
          class="nav-link"
          aria-current={currentPath.startsWith(`${baseUrl}/packages`) ? 'page' : undefined}
        >
          Packages
        </a>
        <a 
          href={`${baseUrl}/mcp-servers/`} 
          class="nav-link"
          aria-current={currentPath.startsWith(`${baseUrl}/mcp-servers`) ? 'page' : undefined}
        >
          MCP Servers
        </a>
        <a 
          href={`${baseUrl}/getting-started/`} 
          class="nav-link"
          aria-current={currentPath.startsWith(`${baseUrl}/getting-started`) ? 'page' : undefined}
        >
          Getting Started
        </a>
        <a 
          href="https://github.com/thomast1906/github-copilot-agent-skills" 
          target="_blank" 
          rel="noopener noreferrer"
          class="nav-link nav-link-external"
        >
          <svg width="20" height="20" viewBox="0 0 16 16" fill="currentColor">
            <path d="M8 0c4.42 0 8 3.58 8 8a8.013 8.013 0 0 1-5.45 7.59c-.4.08-.55-.17-.55-.38 0-.27.01-1.13.01-2.2 0-.75-.25-1.23-.54-1.48 1.78-.2 3.65-.88 3.65-3.95 0-.88-.31-1.59-.82-2.15.08-.2.36-1.02-.08-2.12 0 0-.67-.22-2.2.82-.64-.18-1.32-.27-2-.27-.68 0-1.36.09-2 .27-1.53-1.03-2.2-.82-2.2-.82-.44 1.1-.16 1.92-.08 2.12-.51.56-.82 1.28-.82 2.15 0 3.06 1.86 3.75 3.64 3.95-.23.2-.44.55-.51 1.07-.46.21-1.61.55-2.33-.66-.15-.24-.6-.83-1.23-.82-.67.01-.27.38.01.53.34.19.73.9.82 1.13.16.45.68 1.31 2.69.94 0 .67.01 1.3.01 1.49 0 .21-.15.45-.55.38A7.995 7.995 0 0 1 0 8c0-4.42 3.58-8 8-8Z"></path>
          </svg>
          <span class="sr-only">GitHub</span>
        </a>
      </nav>
      
      <button class="hamburger" id="hamburger" aria-label="Toggle menu" aria-expanded="false">
        <span></span>
        <span></span>
        <span></span>
      </button>
    </div>
  </div>
</header>

<script>
  const hamburger = document.getElementById('hamburger');
  const nav = document.getElementById('nav');
  
  hamburger?.addEventListener('click', () => {
    const isOpen = nav?.classList.toggle('open');
    hamburger?.setAttribute('aria-expanded', isOpen ? 'true' : 'false');
  });
</script>

<style>
  .header {
    position: sticky;
    top: 0;
    z-index: 100;
    background: rgba(13, 17, 23, 0.9);
    backdrop-filter: blur(10px);
    border-bottom: 1px solid var(--color-border);
  }

  .header-content {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: var(--space-4) 0;
    gap: var(--space-6);
  }

  .logo {
    font-size: var(--text-xl);
    font-weight: 700;
    color: var(--color-text-primary);
    text-decoration: none;
    display: flex;
    align-items: center;
    gap: var(--space-2);
  }

  .logo:hover {
    text-decoration: none;
    color: var(--color-accent-primary);
  }

  .nav {
    display: flex;
    align-items: center;
    gap: var(--space-6);
  }

  .nav-link {
    color: var(--color-text-secondary);
    font-size: var(--text-base);
    font-weight: 500;
    text-decoration: none;
    transition: color 0.2s ease;
    display: flex;
    align-items: center;
    gap: var(--space-2);
  }

  .nav-link:hover {
    color: var(--color-text-primary);
    text-decoration: none;
  }

  .nav-link[aria-current="page"] {
    color: var(--color-text-primary);
  }

  .nav-link-external svg {
    flex-shrink: 0;
  }

  .hamburger {
    display: none;
    flex-direction: column;
    gap: 4px;
    background: none;
    border: none;
    cursor: pointer;
    padding: var(--space-2);
    margin-right: calc(var(--space-2) * -1);
  }

  .hamburger span {
    width: 24px;
    height: 2px;
    background: var(--color-text-primary);
    transition: all 0.3s ease;
  }

  @media (max-width: 768px) {
    .nav {
      position: absolute;
      top: 100%;
      left: 0;
      right: 0;
      background: var(--color-bg-secondary);
      border-bottom: 1px solid var(--color-border);
      flex-direction: column;
      align-items: stretch;
      gap: 0;
      padding: var(--space-4) 0;
      display: none;
    }

    .nav.open {
      display: flex;
    }

    .nav-link {
      padding: var(--space-3) var(--space-6);
    }

    .hamburger {
      display: flex;
    }

    .hamburger[aria-expanded="true"] span:nth-child(1) {
      transform: rotate(45deg) translate(5px, 5px);
    }

    .hamburger[aria-expanded="true"] span:nth-child(2) {
      opacity: 0;
    }

    .hamburger[aria-expanded="true"] span:nth-child(3) {
      transform: rotate(-45deg) translate(6px, -6px);
    }
  }
</style>
