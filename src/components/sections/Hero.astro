---
import Button from '../ui/Button.astro';

const baseUrl = import.meta.env.BASE_URL || '/github-copilot-agent-skills';
---

<section class="hero">
  <div class="container">
    <div class="hero-content">
      <div class="logo">⚡</div>
      <h1>GitHub Copilot Agent Skills</h1>
      <p class="headline">Supercharge your Copilot with reusable skills, pre-built agents, and one-command installs.</p>
      <p class="subheading">A curated collection of GitHub Copilot agent skills for platform engineers, cloud architects, and DevOps practitioners. Install bundles with APM, or pick skills individually.</p>
      
      <div class="cta-buttons">
        <Button href={`${baseUrl}/getting-started/`} variant="primary">Get Started →</Button>
        <Button href="https://github.com/thomast1906/github-copilot-agent-skills" variant="secondary" external>View on GitHub →</Button>
      </div>
      
      <div class="stats">
        <span>14 Skills</span>
        <span>·</span>
        <span>4 Agents</span>
        <span>·</span>
        <span>3 Packages</span>
        <span>·</span>
        <span>MIT License</span>
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    background: var(--color-bg-primary);
    position: relative;
    padding: var(--space-24) 0 var(--space-20);
    overflow: hidden;
  }

  .hero::before {
    content: '';
    position: absolute;
    top: 0;
    left: 50%;
    transform: translateX(-50%);
    width: 100%;
    height: 100%;
    background: radial-gradient(circle at center top, rgba(88, 166, 255, 0.08) 0%, transparent 60%);
    pointer-events: none;
  }

  .hero-content {
    position: relative;
    text-align: center;
    max-width: 900px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-6);
  }

  .logo {
    font-size: 5rem;
    line-height: 1;
  }

  h1 {
    font-size: var(--text-5xl);
    font-weight: 700;
    line-height: var(--leading-tight);
    color: var(--color-text-primary);
  }

  @media (max-width: 768px) {
    h1 {
      font-size: var(--text-4xl);
    }
  }

  .headline {
    font-size: var(--text-2xl);
    line-height: var(--leading-normal);
    color: var(--color-text-primary);
  }

  @media (max-width: 768px) {
    .headline {
      font-size: var(--text-xl);
    }
  }

  .subheading {
    font-size: var(--text-lg);
    line-height: var(--leading-relaxed);
    color: var(--color-text-secondary);
    max-width: 700px;
  }

  @media (max-width: 768px) {
    .subheading {
      font-size: var(--text-base);
    }
  }

  .cta-buttons {
    display: flex;
    gap: var(--space-4);
    flex-wrap: wrap;
    justify-content: center;
    margin-top: var(--space-4);
  }

  .stats {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    font-size: var(--text-sm);
    color: var(--color-text-secondary);
    margin-top: var(--space-6);
  }

  .stats span:not(:nth-child(2n)) {
    font-weight: 600;
  }
</style>
