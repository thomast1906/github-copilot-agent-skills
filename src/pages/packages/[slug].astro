---
import BaseLayout from '../../components/layout/BaseLayout.astro';
import CodeBlock from '../../components/ui/CodeBlock.astro';
import AgentCard from '../../components/cards/AgentCard.astro';
import SkillCard from '../../components/cards/SkillCard.astro';
import { getCollection, type CollectionEntry } from 'astro:content';

export async function getStaticPaths() {
  const packages = await getCollection('packages');
  return packages.map((pkg) => ({
    params: { slug: pkg.slug },
    props: { pkg },
  }));
}

interface Props {
  pkg: CollectionEntry<'packages'>;
}

const { pkg } = Astro.props;
const baseUrl = import.meta.env.BASE_URL;

const allAgents = await getCollection('agents');
const includedAgents = allAgents.filter(agent => pkg.data.agents.includes(agent.slug));

const allSkills = await getCollection('skills');
const includedSkills = allSkills.filter(skill => pkg.data.skills.includes(skill.slug));

const allMcpServers = await getCollection('mcp-servers');
const requiredMcp = allMcpServers.filter(server => pkg.data.mcp.includes(server.data.name));

const githubUrl = `https://github.com/thomast1906/github-copilot-agent-skills/tree/main/packages/${pkg.slug}`;
---

<BaseLayout
  title={pkg.data.name}
  description={pkg.body}
>
  <article class="page">
    <div class="container">
      <a href={`${baseUrl}/packages/`} class="back-link">← Back to Packages</a>

      <header class="package-header">
        <div class="header-icon">📦</div>
        <div class="header-text">
          <h1>{pkg.data.name}</h1>
          <p class="description">{pkg.body}</p>
        </div>
      </header>

      <div class="install-section">
        <h2>Install</h2>
        <CodeBlock code={pkg.data.installCommand} label="APM Install Command" />
        <a href={githubUrl} target="_blank" rel="noopener noreferrer" class="github-link">
          View package on GitHub
          <svg width="16" height="16" viewBox="0 0 16 16" fill="currentColor">
            <path d="M3.75 2h3.5a.75.75 0 0 1 0 1.5h-3.5a.25.25 0 0 0-.25.25v8.5c0 .138.112.25.25.25h8.5a.25.25 0 0 0 .25-.25v-3.5a.75.75 0 0 1 1.5 0v3.5A1.75 1.75 0 0 1 12.25 14h-8.5A1.75 1.75 0 0 1 2 12.25v-8.5C2 2.784 2.784 2 3.75 2Zm6.854-1h4.146a.25.25 0 0 1 .25.25v4.146a.25.25 0 0 1-.427.177L13.03 4.03 9.28 7.78a.751.751 0 0 1-1.042-.018.751.751 0 0 1-.018-1.042l3.75-3.75-1.543-1.543A.25.25 0 0 1 10.604 1Z"></path>
          </svg>
        </a>
      </div>

      {includedAgents.length > 0 && (
        <section class="section">
          <h2>Included Agents</h2>
          <p class="section-intro">This package installs the following agents:</p>
          <div class="agents-grid">
            {includedAgents.map((agent) => (
              <AgentCard agent={agent} />
            ))}
          </div>
        </section>
      )}

      {includedSkills.length > 0 && (
        <section class="section">
          <h2>Included Skills</h2>
          <p class="section-intro">This package installs the following skills:</p>
          <div class="skills-grid">
            {includedSkills.map((skill) => (
              <SkillCard skill={skill} />
            ))}
          </div>
        </section>
      )}

      {requiredMcp.length > 0 && (
        <section class="section">
          <h2>MCP Requirements</h2>
          <p class="section-intro">Some skills in this package require MCP servers to be configured:</p>
          <div class="mcp-list">
            {requiredMcp.map((server) => (
              <div class="mcp-item">
                <h3>{server.data.name}</h3>
                <p>{server.body}</p>
                <div class="setup-box">
                  <strong>Setup:</strong> {server.data.installation}
                </div>
              </div>
            ))}
          </div>
        </section>
      )}
    </div>
  </article>
</BaseLayout>

<style>
  .page {
    padding: var(--space-20) 0 var(--space-24);
  }

  .back-link {
    display: inline-flex;
    align-items: center;
    color: var(--color-text-link);
    font-size: var(--text-sm);
    font-weight: 600;
    text-decoration: none;
    margin-bottom: var(--space-8);
  }

  .back-link:hover {
    text-decoration: underline;
  }

  .package-header {
    display: flex;
    gap: var(--space-6);
    align-items: flex-start;
    margin-bottom: var(--space-10);
  }

  .header-icon {
    font-size: 3rem;
    line-height: 1;
    flex-shrink: 0;
  }

  .header-text {
    flex: 1;
  }

  h1 {
    font-size: var(--text-5xl);
    font-weight: 700;
    line-height: var(--leading-tight);
    color: var(--color-text-primary);
    margin-bottom: var(--space-4);
  }

  @media (max-width: 768px) {
    h1 {
      font-size: var(--text-4xl);
    }

    .package-header {
      flex-direction: column;
    }
  }

  .description {
    font-size: var(--text-xl);
    line-height: var(--leading-relaxed);
    color: var(--color-text-secondary);
  }

  .install-section {
    background: var(--color-bg-secondary);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    padding: var(--space-8);
    margin-bottom: var(--space-4);
  }

  .install-section h2 {
    font-size: var(--text-2xl);
    font-weight: 700;
    color: var(--color-text-primary);
    margin-bottom: var(--space-4);
  }

  .github-link {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    color: var(--color-text-link);
    font-size: var(--text-sm);
    font-weight: 600;
    text-decoration: none;
    margin-top: var(--space-4);
  }

  .github-link:hover {
    text-decoration: underline;
  }

  .section {
    margin-top: var(--space-16);
    padding-top: var(--space-16);
    border-top: 1px solid var(--color-border);
  }

  .section h2 {
    font-size: var(--text-3xl);
    font-weight: 700;
    color: var(--color-text-primary);
    margin-bottom: var(--space-4);
  }

  .section-intro {
    font-size: var(--text-lg);
    color: var(--color-text-secondary);
    margin-bottom: var(--space-8);
  }

  .agents-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: var(--space-6);
  }

  @media (min-width: 768px) {
    .agents-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  .skills-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: var(--space-6);
  }

  @media (min-width: 768px) {
    .skills-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .skills-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .mcp-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
  }

  .mcp-item {
    background: var(--color-bg-secondary);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    padding: var(--space-6);
  }

  .mcp-item h3 {
    font-size: var(--text-xl);
    font-weight: 600;
    color: var(--color-text-primary);
    margin-bottom: var(--space-3);
  }

  .mcp-item p {
    color: var(--color-text-secondary);
    line-height: var(--leading-relaxed);
    margin-bottom: var(--space-4);
  }

  .setup-box {
    background: var(--color-bg-tertiary);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    padding: var(--space-4);
    font-size: var(--text-sm);
    color: var(--color-text-secondary);
  }

  .setup-box strong {
    color: var(--color-text-primary);
  }
</style>
