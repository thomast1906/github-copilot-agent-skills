---
import BaseLayout from '../../components/layout/BaseLayout.astro';
import SectionHeader from '../../components/sections/SectionHeader.astro';
import CodeBlock from '../../components/ui/CodeBlock.astro';
import MCPServerCard from '../../components/sections/MCPServerCard.astro';
import { getCollection } from 'astro:content';

const mcpServers = await getCollection('mcp-servers');
---

<BaseLayout 
  title="Getting Started"
  description="Install GitHub Copilot agent skills in minutes with APM or by cloning the repository."
>
  <div class="page">
    <div class="container">
      <SectionHeader 
        title="Getting Started" 
        description="Install agent skills and start using them with GitHub Copilot in minutes."
      />
      
      <section class="section">
        <h2>Prerequisites</h2>
        <ul class="checklist">
          <li><strong>VS Code</strong> with GitHub Copilot extension installed</li>
          <li><strong>GitHub Copilot</strong> subscription (Individual, Business, or Enterprise)</li>
          <li><strong>Git</strong> (for cloning the repository)</li>
        </ul>
      </section>
      
      <section class="section">
        <h2>Option A: Install with APM (Recommended)</h2>
        <p class="intro">
          The Agent Package Manager (APM) makes it easy to install curated bundles of agents and skills.
        </p>
        
        <div class="step">
          <h3>Step 1: Install a Package</h3>
          <p>Choose a package and run the install command:</p>
          <CodeBlock 
            code="apm install thomast1906/github-copilot-agent-skills/packages/architect --runtime vscode"
            label="Architect Bundle"
          />
          <CodeBlock 
            code="apm install thomast1906/github-copilot-agent-skills/packages/terraform --runtime vscode"
            label="Terraform Bundle"
          />
          <CodeBlock 
            code="apm install thomast1906/github-copilot-agent-skills/packages/diagramming --runtime vscode"
            label="Diagramming Bundle"
          />
        </div>
        
        <div class="step">
          <h3>Step 2: Restart VS Code</h3>
          <p>Close and reopen VS Code to load the newly installed agents and skills.</p>
        </div>
        
        <div class="step">
          <h3>Step 3: Open Copilot Chat</h3>
          <p>
            Open GitHub Copilot Chat in VS Code. You'll see the installed agents available in the agent picker. 
            Select an agent and start chatting!
          </p>
        </div>
      </section>
      
      <section class="section">
        <h2>Option B: Clone the Repository</h2>
        <p class="intro">
          If you prefer to work directly with the source, you can clone the repository and use the agents locally.
        </p>
        
        <CodeBlock 
          code="git clone https://github.com/thomast1906/github-copilot-agent-skills.git"
          label="Clone"
        />
        
        <p class="note">
          After cloning, open the repository in VS Code. GitHub Copilot will automatically detect
          the agents defined in <code>.github/agents/</code> and skills in <code>.github/skills/</code>.
        </p>
      </section>
      
      <section class="section">
        <h2>MCP Server Setup</h2>
        <p class="intro">
          Some skills require MCP servers to be configured. Install the servers you need based on which skills you're using.
        </p>
        
        <div class="mcp-grid">
          {mcpServers.map((server) => (
            <MCPServerCard server={server} />
          ))}
        </div>
      </section>
      
      <section class="section">
        <h2>First Use Example</h2>
        <p class="intro">
          Once installed, try asking the Azure Architect agent to design a web application architecture:
        </p>
        
        <CodeBlock 
          code="@azure-architect Design a production-ready architecture for a Node.js web application on Azure. Include a managed database, caching layer, and CDN. Estimate monthly costs for 10,000 users."
          label="Example Prompt"
        />
        
        <p class="note">
          The agent will use the Architecture Design, WAF Assessment, and Azure Pricing skills to generate 
          a comprehensive HLD document with service recommendations and cost estimates.
        </p>
      </section>
    </div>
  </div>
</BaseLayout>

<style>
  .page {
    padding: var(--space-20) 0 var(--space-24);
  }

  .section {
    margin-top: var(--space-16);
    padding-top: var(--space-16);
    border-top: 1px solid var(--color-border);
  }

  .section:first-of-type {
    margin-top: 0;
    padding-top: 0;
    border-top: none;
  }

  .section h2 {
    font-size: var(--text-3xl);
    font-weight: 700;
    line-height: var(--leading-tight);
    color: var(--color-text-primary);
    margin-bottom: var(--space-6);
  }

  .intro {
    font-size: var(--text-lg);
    color: var(--color-text-secondary);
    line-height: var(--leading-relaxed);
    margin-bottom: var(--space-8);
  }

  .checklist {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .checklist li {
    display: flex;
    align-items: flex-start;
    gap: var(--space-3);
    color: var(--color-text-secondary);
    line-height: var(--leading-relaxed);
  }

  .checklist li::before {
    content: '✓';
    color: var(--color-accent-secondary);
    font-weight: bold;
    font-size: var(--text-lg);
    flex-shrink: 0;
  }

  .checklist strong {
    color: var(--color-text-primary);
  }

  .step {
    margin-bottom: var(--space-10);
  }

  .step:last-child {
    margin-bottom: 0;
  }

  .step h3 {
    font-size: var(--text-xl);
    font-weight: 600;
    color: var(--color-text-primary);
    margin-bottom: var(--space-3);
  }

  .step p {
    color: var(--color-text-secondary);
    line-height: var(--leading-relaxed);
    margin-bottom: var(--space-4);
  }

  .note {
    font-size: var(--text-sm);
    color: var(--color-text-secondary);
    line-height: var(--leading-relaxed);
    background: var(--color-bg-tertiary);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    padding: var(--space-4);
    margin-top: var(--space-6);
  }

  .note code {
    font-size: var(--text-xs);
  }

  .mcp-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: var(--space-6);
  }

  @media (min-width: 768px) {
    .mcp-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
</style>
