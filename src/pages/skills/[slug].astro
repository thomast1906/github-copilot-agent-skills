---
import BaseLayout from '../../components/layout/BaseLayout.astro';
import StatusBadge from '../../components/ui/StatusBadge.astro';
import CategoryBadge from '../../components/ui/CategoryBadge.astro';
import AgentCard from '../../components/cards/AgentCard.astro';
import PackageCard from '../../components/cards/PackageCard.astro';
import { getCollection, render, type CollectionEntry } from 'astro:content';

export async function getStaticPaths() {
  const skills = await getCollection('skills');
  return skills.map((skill) => ({
    params: { slug: skill.slug },
    props: { skill },
  }));
}

interface Props {
  skill: CollectionEntry<'skills'>;
}

const { skill } = Astro.props;
const baseUrl = import.meta.env.BASE_URL || '/github-copilot-agent-skills';

const { Content } = await render(skill);

const allMcpServers = await getCollection('mcp-servers');
const relatedMcpServers = allMcpServers.filter(server => 
  skill.data.mcp.includes(server.data.name)
);

const allAgents = await getCollection('agents');
const relatedAgents = allAgents.filter(agent => 
  agent.data.skills.includes(skill.slug)
);

const allPackages = await getCollection('packages');
const relatedPackages = allPackages.filter(pkg => 
  pkg.data.skills.includes(skill.slug)
);
---

<BaseLayout 
  title={skill.data.name}
  description={skill.body}
>
  <article class="page">
    <div class="container">
      <a href={`${baseUrl}/skills/`} class="back-link">← Back to Skills</a>
      
      <header class="skill-header">
        <h1>{skill.data.name}</h1>
        <div class="badges">
          <StatusBadge status={skill.data.status} />
          <CategoryBadge category={skill.data.category} />
        </div>
      </header>
      
      <div class="description">
        <Content />
      </div>
      
      {relatedMcpServers.length > 0 && (
        <section class="section">
          <h2>MCP Requirements</h2>
          <p class="section-intro">This skill requires the following MCP servers to be configured:</p>
          <div class="mcp-list">
            {relatedMcpServers.map((server) => (
              <div class="mcp-item">
                <h3>{server.data.name}</h3>
                <p>{server.body}</p>
                <div class="setup-box">
                  <strong>Setup:</strong> {server.data.installation}
                </div>
              </div>
            ))}
          </div>
        </section>
      )}
      
      {relatedAgents.length > 0 && (
        <section class="section">
          <h2>Related Agents</h2>
          <p class="section-intro">This skill is used by the following agents:</p>
          <div class="agents-grid">
            {relatedAgents.map((agent) => (
              <AgentCard agent={agent} />
            ))}
          </div>
        </section>
      )}
      
      {relatedPackages.length > 0 && (
        <section class="section">
          <h2>Included in Packages</h2>
          <p class="section-intro">Install this skill as part of these packages:</p>
          <div class="packages-grid">
            {relatedPackages.map((pkg) => (
              <PackageCard package={pkg} />
            ))}
          </div>
        </section>
      )}
    </div>
  </article>
</BaseLayout>

<style>
  .page {
    padding: var(--space-20) 0 var(--space-24);
  }

  .back-link {
    display: inline-flex;
    align-items: center;
    color: var(--color-text-link);
    font-size: var(--text-sm);
    font-weight: 600;
    text-decoration: none;
    margin-bottom: var(--space-8);
  }

  .back-link:hover {
    text-decoration: underline;
  }

  .skill-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: var(--space-6);
    margin-bottom: var(--space-6);
    flex-wrap: wrap;
  }

  h1 {
    font-size: var(--text-5xl);
    font-weight: 700;
    line-height: var(--leading-tight);
    color: var(--color-text-primary);
  }

  @media (max-width: 768px) {
    h1 {
      font-size: var(--text-4xl);
    }
  }

  .badges {
    display: flex;
    gap: var(--space-3);
    flex-wrap: wrap;
  }

  .description {
    font-size: var(--text-xl);
    line-height: var(--leading-relaxed);
    color: var(--color-text-secondary);
    margin-bottom: var(--space-12);
  }

  .description :global(p) {
    margin-bottom: var(--space-4);
  }

  .description :global(p:last-child) {
    margin-bottom: 0;
  }

  .section {
    margin-top: var(--space-16);
    padding-top: var(--space-16);
    border-top: 1px solid var(--color-border);
  }

  .section h2 {
    font-size: var(--text-3xl);
    font-weight: 700;
    line-height: var(--leading-tight);
    color: var(--color-text-primary);
    margin-bottom: var(--space-4);
  }

  .section-intro {
    font-size: var(--text-lg);
    color: var(--color-text-secondary);
    margin-bottom: var(--space-8);
  }

  .mcp-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
  }

  .mcp-item {
    background: var(--color-bg-secondary);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    padding: var(--space-6);
  }

  .mcp-item h3 {
    font-size: var(--text-xl);
    font-weight: 600;
    color: var(--color-text-primary);
    margin-bottom: var(--space-3);
  }

  .mcp-item p {
    color: var(--color-text-secondary);
    line-height: var(--leading-relaxed);
    margin-bottom: var(--space-4);
  }

  .setup-box {
    background: var(--color-bg-tertiary);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    padding: var(--space-4);
    font-size: var(--text-sm);
    color: var(--color-text-secondary);
  }

  .setup-box strong {
    color: var(--color-text-primary);
  }

  .agents-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: var(--space-6);
  }

  @media (min-width: 768px) {
    .agents-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  .packages-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
    gap: var(--space-8);
  }

  @media (min-width: 1024px) {
    .packages-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
</style>
